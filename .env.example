# === Cle API Anthropic (Claude) - obligatoire ===
# Cree ta cle ici : https://console.anthropic.com/settings/keys
# 1. Cree un compte (carte bancaire requise, $5 de credit gratuit a l'inscription)
# 2. Settings > API Keys > Create Key
# 3. Renomme ce fichier ".env.example" en ".env"
# 4. Colle la cle apres le "=" ci-dessous

ANTHROPIC_API_KEY=ta_cle_ici

# === Cle API Spoonacular - pour les vraies photos de plats (optionnel mais recommande) ===
# Cree ta cle ici : https://spoonacular.com/food-api
# Gratuit : 150 requetes/jour
# Sans cle : on fallback sur des images IA Pollinations (plus lent, moins joli)

SPOONACULAR_API_KEY=ta_cle_ici
